# ============================================================
# Congress Trades — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in optional values.
# The app runs with zero API keys using public data sources.
# Keys below unlock richer data but are NOT required.
# ============================================================

# -- OPTIONAL: Quiver Quantitative (free tier key) ----------
# Sign up at https://www.quiverquant.com/account/login
# Used as a fallback/supplement for STOCK Act disclosures
QUIVER_QUANT_API_KEY=

# -- OPTIONAL: Congress.gov API (free key) ------------------
# Get a free key at https://api.congress.gov/sign-up
# Used for member photo thumbnails and official committee data
CONGRESS_API_KEY=

# -- OPTIONAL: Alpha Vantage (free tier key) ----------------
# Get a free key at https://www.alphavantage.co/support/#api-key
# Used as fallback price source if Yahoo Finance is unavailable
ALPHA_VANTAGE_KEY=

# -- DATA PIPELINE SETTINGS ---------------------------------
# Number of years of historical trade data to ingest
PIPELINE_YEARS_BACK=5
# Whether to use cached data if fresh fetch fails
PIPELINE_USE_CACHE=true
# Log level: DEBUG | INFO | WARNING | ERROR
PIPELINE_LOG_LEVEL=INFO

# -- NEXT.JS SETTINGS ---------------------------------------
# Revalidation interval in seconds for ISR pages (default 6 hours)
NEXT_REVALIDATE_SECONDS=21600
